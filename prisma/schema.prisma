generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  cards         VCard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VCard {
  id                 String         @id @default(cuid())
  userId             String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  firstName          String
  lastName           String
  displayName        String?
  jobTitle           String
  headline           String?
  bio                String?
  pronouns           String?
  avatarUrl          String?
  companyName        String?
  companyRole        String?
  companyLogoUrl     String?
  companyWebsite     String?
  companyIndustry    String?
  companyTagline     String?
  slug               String         @unique
  isPublished        Boolean        @default(false)
  leadCaptureEnabled Boolean        @default(true)
  vcfDownloadEnabled Boolean        @default(true)
  showViewCount      Boolean        @default(false)
  seoTitle           String?
  seoDescription     String?
  language           String         @default("en")
  themePreset        String         @default("ocean-cyan")
  backgroundStyle    String         @default("gradient")
  colorPrimary       String         @default("#171717")
  colorSecondary     String         @default("#3b82f6")
  colorAccent        String         @default("#2563eb")
  textColor          String         @default("#171717")
  subtextColor       String         @default("#52525b")
  layout             String         @default("classic")
  headerGlass        Boolean        @default(false)
  avatarNeonRing     Boolean        @default(false)
  particles          Boolean        @default(false)
  coverImageUrl      String?
  backgroundImageUrl String?
  totalViews         Int            @default(0)
  uniqueViews        Int            @default(0)
  totalClicks        Int            @default(0)
  leadsCollected     Int            @default(0)
  vcfDownloads       Int            @default(0)
  actionLinks        ActionLink[]
  addresses          AddressEntry[]
  emails             EmailEntry[]
  leads              Lead[]
  mediaEmbeds        MediaEmbed[]
  paymentLinks       PaymentLink[]
  phones             PhoneEntry[]
  socialLinks        SocialLink[]
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  websites           WebsiteEntry[]
}

model PhoneEntry {
  id        String  @id @default(cuid())
  vcardId   String
  type      String
  number    String
  label     String?
  whatsapp  Boolean @default(false)
  sms       Boolean @default(true)
  isPrimary Boolean @default(false)
  vcard     VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model EmailEntry {
  id        String  @id @default(cuid())
  vcardId   String
  type      String
  address   String
  label     String?
  isPrimary Boolean @default(false)
  vcard     VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model AddressEntry {
  id         String  @id @default(cuid())
  vcardId    String
  type       String
  label      String?
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  mapUrl     String?
  vcard      VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model WebsiteEntry {
  id       String  @id @default(cuid())
  vcardId  String
  label    String
  url      String
  featured Boolean @default(false)
  vcard    VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id        String  @id @default(cuid())
  vcardId   String
  platform  String
  url       String
  handle    String?
  label     String?
  order     Int     @default(0)
  isVisible Boolean @default(true)
  vcard     VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model PaymentLink {
  id        String  @id @default(cuid())
  vcardId   String
  platform  String
  url       String
  label     String?
  note      String?
  order     Int     @default(0)
  isVisible Boolean @default(true)
  vcard     VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model ActionLink {
  id        String  @id @default(cuid())
  vcardId   String
  platform  String
  url       String
  label     String
  subtitle  String?
  icon      String?
  color     String?
  order     Int     @default(0)
  isVisible Boolean @default(true)
  vcard     VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model MediaEmbed {
  id           String  @id @default(cuid())
  vcardId      String
  type         String
  url          String
  title        String?
  thumbnailUrl String?
  order        Int     @default(0)
  isVisible    Boolean @default(true)
  vcard        VCard   @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}


model Lead {
  id        String   @id @default(cuid())
  vcardId   String
  createdAt DateTime @default(now())
  name      String
  email     String?
  phone     String?
  company   String?
  jobTitle  String?
  note      String?
  vcard     VCard    @relation(fields: [vcardId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id               String   @id @default("global")
  defaultTemplate  String   @default("classic")
  customDomains    Boolean  @default(false)
  whiteLabel       Boolean  @default(false)
  ipWhitelisting   Boolean  @default(false)
  googleOAuth      Boolean  @default(true)
  maintenanceMode  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}
